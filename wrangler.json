{
	"name": "d1-template",
	"main": "src/index.ts",
	"compatibility_date": "2025-05-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"ai": {
		"binding": "AI"
	},
	"r2_buckets": [
		{
			"binding": "PDF_BUCKET",
			"bucket_name": "vault-test-bytes"
		}
	],
	"d1_databases": [
		{
			"binding": "META_DB",
			"database_name": "vault-test-meta",
			"database_id": "669933e3-cad2-49cc-bbda-efbb4c653120"
		}
	],
	"vectorize": [
		{
			"binding": "VECTORS",
			"index_name": "vault-test-vectors"
		}
	],
	"vars": {
		"ALLOWED_ORIGINS": "*",
		"PDF_SINGLE_PUT_MAX_BYTES": "99614720",
		"EMBEDDING_MODEL": "@cf/baai/bge-small-en-v1.5",
		"EMBEDDING_DIMENSIONS": "384"
	}
}